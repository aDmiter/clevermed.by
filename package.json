{
  "name": "clevermed-by",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "prisma generate && next build && node scripts/beget-postbuild.mjs",
    "start": "next start -p 3002",
    "start:beget": "NODE_ENV=production node server.js",
    "beget:restart": "node -e \"require('fs').mkdirSync('tmp',{recursive:true}); require('fs').utimesSync('tmp/restart.txt', new Date(), new Date())\"",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:apply-rbac": "prisma db execute --file prisma/migrations/20260521120000_admin_rbac/migration.sql",
    "db:apply-drop-procedures": "prisma db execute --file prisma/migrations/20260522130000_drop_procedures/migration.sql",
    "db:apply-analytics": "prisma db execute --file prisma/migrations/20260522140000_site_analytics/migration.sql",
    "db:setup": "npm run db:apply-rbac && prisma db seed",
    "db:seed": "prisma db seed",
    "auth:reset-admin": "tsx scripts/reset-admin-password.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "mariadb": "^3.5.2",
    "motion": "^12.39.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^7.8.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
