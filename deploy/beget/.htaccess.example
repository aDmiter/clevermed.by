# Скопируйте в корень проекта на Beget как .htaccess
# Замените USER на логин аккаунта Beget (путь /home/u/USER/...)

PassengerNodejs /home/u/USER/.local/bin/node
PassengerAppRoot /home/u/USER/clevermed.by
PassengerAppType node
PassengerStartupFile server.js
PassengerAppEnv production

# Не коммитьте реальный .htaccess с паролями — только на сервере
