# MySQL connection (required)
# XAMPP local example (after setup): mysql://clevermed:clevermed_local@localhost:3306/clevermed
DATABASE_URL="mysql://clevermed:YOUR_PASSWORD@localhost:3306/clevermed"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL=http://localhost:3002

# Initial admin (used by prisma db seed)
ADMIN_EMAIL="admin@clevermed.by"
ADMIN_PASSWORD="change-me-in-production"
