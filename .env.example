# MySQL connection (required)
# XAMPP local example (after setup): mysql://clevermed:clevermed_local@localhost:3306/clevermed
DATABASE_URL="mysql://clevermed:YOUR_PASSWORD@localhost:3306/clevermed"
# Для `npm run db:migrate` (migrate dev): отдельная shadow-БД, созданная вручную в MySQL:
# SHADOW_DATABASE_URL="mysql://clevermed:YOUR_PASSWORD@localhost:3306/clevermed_shadow"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL=http://localhost:3002

# Initial super admin (used by prisma db seed)
ADMIN_LOGIN=superadmin
ADMIN_EMAIL=admin@clevermed.by
# Min 12 chars, upper, lower, digit, special (see lib/auth/password.ts)
ADMIN_PASSWORD=ChangeMe!Secure2026
